{
  "project": "agent-orchestrator",
  "domains": [
    {
      "id": "domain:agent-orchestration",
      "name": "Agent Orchestration",
      "description": "Core domain for coordinating multi-agent workflows",
      "flows": [
        {
          "id": "flow:task-routing",
          "name": "Task Routing",
          "description": "Route user tasks to appropriate model (Kimi/DeepSeek/MiniMax)",
          "steps": [
            {"id": "step:analyze-task", "name": "Analyze Task", "description": "Kimi analyzes task to determine mode (plan/build)"},
            {"id": "step:generate-plan", "name": "Generate Plan", "description": "Generate structured plan with items"},
            {"id": "step:execute-items", "name": "Execute Items", "description": "Execute plan items sequentially"},
            {"id": "step:checkpoint-review", "name": "Checkpoint Review", "description": "Kimi reviews progress every 4 items"}
          ]
        },
        {
          "id": "flow:skill-execution",
          "name": "Skill Auto-Execution",
          "description": "Automatically execute skills from plan recommendations",
          "steps": [
            {"id": "step:parse-skills", "name": "Parse Skills", "description": "Parse suggested_skills from plan"},
            {"id": "step:classify-skills", "name": "Classify Skills", "description": "Classify into AUTO/INTERACTIVE/TOOL_REQUIRED"},
            {"id": "step:dispatch-auto", "name": "Dispatch Auto", "description": "Dispatch AUTO skills to subagent"},
            {"id": "step:execute-manual", "name": "Execute Manual", "description": "Execute INTERACTIVE/TOOL_REQUIRED in main session"}
          ]
        }
      ]
    },
    {
      "id": "domain:model-management",
      "name": "Model Management",
      "description": "Manage three-layer model architecture",
      "flows": [
        {
          "id": "flow:model-fallback",
          "name": "Model Fallback",
          "description": "Fallback chain when primary model fails",
          "steps": [
            {"id": "step:try-primary", "name": "Try Primary", "description": "Try primary model (Kimi)"},
            {"id": "step:check-error", "name": "Check Error", "description": "Check if error is retryable (429, 5xx)"},
            {"id": "step:retry-with-backoff", "name": "Retry with Backoff", "description": "Retry with exponential backoff"},
            {"id": "step:fallback-to-secondary", "name": "Fallback to Secondary", "description": "Fallback to secondary model (DeepSeek)"}
          ]
        }
      ]
    },
    {
      "id": "domain:state-management",
      "name": "State Management",
      "description": "Manage plans, checkpoints, and activity logs",
      "flows": [
        {
          "id": "flow:plan-lifecycle",
          "name": "Plan Lifecycle",
          "description": "Full lifecycle of a plan from creation to completion",
          "steps": [
            {"id": "step:create-plan", "name": "Create Plan", "description": "Create plan with items"},
            {"id": "step:update-items", "name": "Update Items", "description": "Update item status (pending/active/completed/failed)"},
            {"id": "step:create-checkpoint", "name": "Create Checkpoint", "description": "Create milestone checkpoint"},
            {"id": "step:verify-checkpoint", "name": "Verify Checkpoint", "description": "Kimi verifies checkpoint"},
            {"id": "step:complete-plan", "name": "Complete Plan", "description": "Mark plan as completed"}
          ]
        }
      ]
    }
  ],
  "entities": [
    {"id": "entity:plan", "name": "Plan", "description": "Structured plan with items"},
    {"id": "entity:plan-item", "name": "Plan Item", "description": "Individual task in a plan"},
    {"id": "entity:checkpoint", "name": "Checkpoint", "description": "Milestone review point"},
    {"id": "entity:skill", "name": "Skill", "description": "Executable skill (P0/P1/P2)"},
    {"id": "entity:model-client", "name": "Model Client", "description": "LLM API client (Kimi/DeepSeek/MiniMax)"}
  ],
  "relationships": [
    {"source": "entity:plan", "target": "entity:plan-item", "type": "contains"},
    {"source": "entity:plan", "target": "entity:checkpoint", "type": "has_checkpoint"},
    {"source": "entity:plan-item", "target": "entity:model-client", "type": "executed_by"},
    {"source": "flow:task-routing", "target": "entity:model-client", "type": "uses"},
    {"source": "flow:skill-execution", "target": "entity:skill", "type": "executes"}
  ]
}
