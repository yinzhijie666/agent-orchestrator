{
  "server": {
    "port": 8765,
    "host": "127.0.0.1"
  },
  "milestone": {
    "interval": 4,
    "verification_timeout_ms": 300000
  },
  "auto_exec": {
    "enabled": true,
    "max_skills": 20,
    "model": "cheap",
    "timeout_ms": 90000,
    "dispatcher": {
      "prefer": "run",
      "server": {
        "port_range": [14096, 14097, 14098, 14099],
        "startup_timeout_ms": 15000,
        "use_pure": true
      },
      "run": {
        "format": "json"
      }
    }
  },
  "models": {
    "kimi": {
      "api_key_env": "OPENCODE_API_KEY",
      "base_url": "https://opencode.ai/zen/go/v1",
      "model": "kimi-k2.6",
      "max_tokens": 262144,
      "thinking": { "type": "enabled" },
      "provider": "opencode-go"
    },
    "deepseek": {
      "api_key_env": "DEEPSEEK_API_KEY",
      "base_url": "https://api.deepseek.com/v1",
      "model": "deepseek-v4-flash",
      "max_tokens": 384000,
      "provider": "deepseek"
    },
    "opencode-zen": {
      "api_key_env": "OPENCODE_API_KEY",
      "base_url": "https://opencode.ai/zen/v1",
      "model": "deepseek-v4-flash-free",
      "max_tokens": 128000,
      "temperature": 0.1,
      "provider": "opencode-zen"
    }
  },
  "workflow": {
    "default_profile": "standard",
    "profiles": {
      "minimal": {
        "phases": [1, 4],
        "phase_1_steps": 4,
        "phase_4_steps": 1,
        "total_steps": 5,
        "use_case": "日常 commit 前自检"
      },
      "standard": {
        "phases": [1, 2, 4],
        "phase_1_steps": 4,
        "phase_2_steps": 13,
        "phase_4_steps": 2,
        "total_steps": 19,
        "use_case": "重大功能前（推荐默认）"
      },
      "full": {
        "phases": [1, 2, 3, 4, 5],
        "phase_1_steps": 4,
        "phase_2_steps": 14,
        "phase_3_steps": 32,
        "phase_4_steps": 2,
        "phase_5_steps": 12,
        "total_steps": 64,
        "use_case": "发版、重大重构"
      },
      "audit": {
        "extends": "full",
        "extras": ["auto-generate-audit-report"],
        "phase_4_steps": 7,
        "total_steps": 69,
        "use_case": "审计场景，产出 audit-report-<date>.md"
      }
    }
  }
}